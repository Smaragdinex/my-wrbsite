---
import '../styles/landing.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>CatInsight Stock — AI-Powered Stock Research</title>
<meta name="description" content="CatInsight Stock — a transparent, machine-learning stock ranking plus an AI research assistant for US and Taiwan markets." />
<link rel="icon" type="image/png" href="assets/favicon.png" />
<link rel="apple-touch-icon" href="assets/icon-180.png" />
<meta property="og:title" content="CatInsight Stock — AI-Powered Stock Research" />
<meta property="og:description" content="A transparent, machine-learning stock ranking plus an AI research assistant for US and Taiwan markets." />
<meta property="og:image" content="assets/icon-180.png" />
</head>
<body>

<div id="intro">
  <div class="orb"><div class="ring r1"></div><div class="ring r2"></div><div class="ring r3"></div><div class="core"></div>
    <img class="catface" src="assets/icon-180.png" alt="CatInsight Stock"><div class="scan"></div></div>
  <div class="intro-word">CatInsight <span class="grad">Stock</span></div>
  <div class="intro-tag">See what the data sees</div>
  <div class="intro-skip">tap to skip</div>
</div>

<nav id="nav"><div class="wrap nav">
  <div class="logo"><img class="mark" src="assets/icon-180.png" alt="CatInsight Stock">CatInsight <span class="grad">Stock</span></div>
  <div class="nav-links"><a href="#features">Features</a><a href="support.html">Support</a><a href="https://apps.apple.com/app/id6763914049" class="btn btn-primary">Get the App</a></div>
</div></nav>

<header class="hero"><div class="wrap">
  <div class="glow a"></div>
  <div class="hero-grid">
    <div class="reveal">
      <span class="pill"><span class="dot2"></span> US &amp; Taiwan markets · Updated daily</span>
      <h1>See what the <span class="grad">data</span> sees.</h1>
      <p class="sub">A transparent, machine-learning stock ranking paired with an AI research assistant — built on real data, not hype.</p>
      <p class="zh">讓數據替你看盤 — AI 選股排名 + 個股 AI 研究助理,涵蓋美股與台股。</p>
      <div class="cta"><a href="https://apps.apple.com/app/id6763914049" class="btn btn-primary">Download on iOS</a><a href="#features" class="btn btn-ghost">Explore features</a></div>
      <p class="note">No account needed · For informational purposes only</p>
    </div>
    <div class="stage reveal">
      <div class="bigorb">
        <div class="ring r1"></div><div class="ring r2"></div><div class="ring r3"></div>
        <div class="core"></div>
        <img class="catface" src="assets/app-icon.png" alt="CatInsight Stock">
        <div class="scan"></div>
        <div class="orbit"><span class="p"></span></div>
        <div class="orbit o2"><span class="p"></span></div>
      </div>
    </div>
  </div>
</div></header>

<div class="tape"><div class="tape-track" id="tape"></div></div>

<section class="catshow">
  <div class="wrap reveal center">
    <div class="eyebrow" style="justify-content:center">Your AI detective</div>
    <h2 class="big">On the case, <span style="color:var(--g2)">24&#47;7</span></h2>
    <p class="lead">Our cat detective scans the market with data — so you don't have to squint at charts.</p>
  </div>
  <div class="catvid full reveal">
    <video autoplay muted loop playsinline poster="assets/cat-poster.jpg">
      <source src="assets/cat-hero.mp4" type="video/mp4">
    </video>
  </div>
</section>

<!-- scroll-pinned cat + phone storytelling -->
<section class="scrolly" id="features"><div class="pin"><div class="wrap"><div class="scene">
  <div class="caption">
    <div class="eyebrow" id="cap-eye">AI Ranking</div>
    <h2 id="cap-title"><span class="grad">Smart</span><span class="grad">Ranking.</span></h2>
    <p id="cap-desc">A daily machine-learning ranking by real fundamentals, technicals and money flow.</p>
    <div class="dots" id="dots"></div>
  </div>
  <div class="stage-wrap">
    <img class="cat-mascot" id="mascot" src="assets/app-icon.png" alt="CatInsight cat">
    <div class="device static" id="liveDevice"><div class="notch"></div><div class="screen" id="scr-live"></div></div>
  </div>
</div></div></div></section>

<section class="pad" style="padding-top:0"><div class="wrap reveal">
  <div class="stats">
    <div class="stat"><div class="big grad">120+</div><div class="cap">Factors per stock</div></div>
    <div class="stat"><div class="big grad">Daily</div><div class="cap">Ranking refresh</div></div>
    <div class="stat"><div class="big grad">2</div><div class="cap">Markets (US · TW)</div></div>
    <div class="stat"><div class="big grad">$0</div><div class="cap">Free to start</div></div>
  </div>
</div></section>

<section id="download" class="pad" style="padding-top:0"><div class="wrap center reveal">
  <div class="eyebrow" style="justify-content:center">Get started</div>
  <h2 class="big">Ready to see what the data sees?</h2>
  <p class="lead">CatInsight Stock is coming to the App Store. No account, no clutter — just sharper research.</p>
  <p style="margin-top:28px"><a href="https://apps.apple.com/app/id6763914049" class="btn btn-primary" style="font-size:16px;padding:14px 28px"> Download on the App Store</a></p>
  <p class="note" style="margin-top:14px">Questions? <a href="mailto:contact@xarts.games" style="color:var(--gtext)">contact@xarts.games</a></p>
</div></section>

<div class="wrap"><div class="disc reveal"><b>Disclaimer.</b> CatInsight Stock is provided for informational and educational purposes only. It is not investment advice and does not execute trades or handle funds. All valuations shown are model reference figures, not recommendations. Market data may be delayed. Investing involves risk, including possible loss of principal.</div></div>

<footer><div class="wrap foot"><div>© 2026 X-Arts Corporation LTD · CatInsight Stock</div>
  <div><a href="privacy.html">Privacy</a><a href="support.html">Support</a><a href="mailto:contact@xarts.games">Contact</a></div></div></footer>

<script is:inline>
// intro
var intro=document.getElementById('intro');
if(intro){if(sessionStorage.getItem('ci_seen')){intro.parentNode.removeChild(intro);}
 else{document.body.style.overflow='hidden';var ended=false;
  function end(){if(ended)return;ended=true;intro.classList.add('out');document.body.style.overflow='';sessionStorage.setItem('ci_seen','1');setTimeout(function(){if(intro.parentNode)intro.parentNode.removeChild(intro);},950);}
  setTimeout(end,3300);intro.addEventListener('click',end);}}

var bar='<div class="tabs"><svg viewBox="0 0 24 24" fill="none" stroke="#0a84ff" stroke-width="2"><path d="M3 17l5-6 4 4 6-8" stroke-linecap="round" stroke-linejoin="round"/></svg><svg viewBox="0 0 24 24" fill="none" stroke="#7a8696" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4" stroke-linecap="round"/></svg><svg viewBox="0 0 24 24" fill="none" stroke="#7a8696" stroke-width="2"><path d="M21 12a8 8 0 0 1-11.6 7.1L4 20l1-5A8 8 0 1 1 21 12z"/></svg><svg viewBox="0 0 24 24" fill="none" stroke="#7a8696" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg></div>';
function sb(){return '<div class="sb"><span>7:30</span><span class="r">📶 🔋</span></div>';}

// ---- build the 4 app screens as strings ----
// watchlist
var wd=[["MU","Micron Technology","$1210.24",1,"2,18 10,12 18,20 26,8 34,16 42,10 50,18 58,5 68,3"],["NVDA","NVIDIA Corporation","$208.65",0,"2,5 12,8 22,12 32,14 44,17 56,19 68,20"],["LITE","Lumentum Holdings","$893.74",1,"2,20 12,16 24,9 36,6 48,8 60,4 68,3"],["AAOI","Applied Optoelectronics","$171.32",1,"2,18 12,17 24,12 36,8 48,6 60,5 68,4"],["AVGO","Broadcom Inc.","$393.10",0,"2,5 14,9 26,8 38,13 50,14 60,17 68,19"]];
var hw=sb()+'<div class="hd"><h4>清單</h4><div class="anbtn">✦ 分析</div></div><div class="rows">';
wd.forEach(function(d){var c=d[3]?'#1fae54':'#e23b4e';hw+='<div class="row"><div class="meta"><div class="sym">'+d[0]+'</div><div class="nm">'+d[1]+'</div></div><svg class="spark" viewBox="0 0 70 24" preserveAspectRatio="none"><polyline fill="none" stroke="'+c+'" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" points="'+d[4]+'"/><line x1="2" y1="11" x2="68" y2="11" stroke="#3a3f48" stroke-width=".6" stroke-dasharray="2 2"/></svg><div class="price '+(d[3]?'up':'down')+'">'+d[2]+'</div></div>';});
hw+='</div>'+bar;

// ranking
var rk=[["1","WDC",100,"+12%"],["2","AMKR",96,"+9%"],["3","MU",91,"+18%"],["4","MRVL",90,"+7%"],["5","ALGM",84,"+6%"],["6","COHU",83,"+5%"],["7","ICHR",81,"+8%"]];
var hr=sb()+'<div class="hd"><h4>排行 · TOP</h4></div><div class="rows">';
rk.forEach(function(d){hr+='<div class="rk"><div class="num">'+d[0]+'</div><div class="sym">'+d[1]+'</div><div class="bar"><i style="width:'+d[2]+'%"></i></div><div class="pc">'+d[3]+'</div></div>';});
hr+='</div>'+bar;

// chart
var cs='';var bars=[[40,70,48,62,0],[38,66,44,58,1],[44,74,52,66,0],[32,60,38,54,1],[28,52,32,46,1],[34,58,40,52,0],[24,48,28,42,1],[20,40,24,36,1],[16,38,20,32,1],[14,34,18,28,1]];
bars.forEach(function(b,i){var x=18+i*22;var c=b[4]?'#1fae54':'#e23b4e';cs+='<line x1="'+x+'" y1="'+b[0]+'" x2="'+x+'" y2="'+b[1]+'" stroke="'+c+'" stroke-width="3"/><line x1="'+x+'" y1="'+b[2]+'" x2="'+x+'" y2="'+b[3]+'" stroke="'+c+'" stroke-width="10"/>';});
var vol='';bars.forEach(function(b,i){var x=18+i*22;var c=b[4]?'#1fae54':'#e23b4e';var h=8+(i%3)*7;vol+='<rect x="'+(x-5)+'" y="'+(40-h)+'" width="10" height="'+h+'" fill="'+c+'" opacity=".5"/>';});
var hc=sb()+'<div class="hd"><h4>SMTC</h4></div><div class="cprice"><b>$174.30</b> <span class="g">+9.6%</span></div><div class="tf"><span>1D</span><span>5D</span><span class="on">1M</span></div><div style="padding:6px 14px"><svg viewBox="0 0 240 90" width="100%" height="120">'+cs+'</svg></div><div style="padding:0 14px"><svg viewBox="0 0 240 42" width="100%" height="46">'+vol+'</svg></div>'+bar;

// chat
var hch=sb()+'<div class="hd"><h4>SMTC</h4></div><div class="chat"><div class="bub u">MACD 交叉了嗎?離高點多遠?</div><div class="bub a">MACD 8.5 已跌破信號線 10.0,屬偏空交叉,動能轉弱。現價 $174.3,距 52 週高點僅 -1.6%,處於高位區。</div><div class="bub u">估值貴嗎?</div><div class="bub a">分析師平均目標 $205(+18%),Strong Buy,但低標 $175 已接近現價。</div></div><div class="inp">繼續問…</div>'+bar;

// ---- scroll-pinned stage engine ----
var shot=function(f){return '<img src="'+f+'" style="width:100%;height:100%;object-fit:cover;display:block">';};
var SCREENS=[shot('assets/shot-list.png?v=3'),shot('assets/shot-rank.png?v=3'),shot('assets/shot-detail.png?v=3'),shot('assets/shot-chat.png?v=3')];
var CAPS=[
 {e:"Your watchlist",t:'<span class="grad">Watchlist,</span><span class="grad">alive.</span>',d:"Live sparklines and momentum colors. One tap to AI-analyze your whole list."},
 {e:"AI Ranking",t:'<span class="grad">Smart</span><span class="grad">Ranking.</span>',d:"A daily machine-learning ranking by real fundamentals, technicals and money flow."},
 {e:"Charts",t:'<span class="grad">Real</span><span class="grad">Data.</span>',d:"Candlesticks, volume and live RSI / MACD / VWAP — the numbers, not a guess."},
 {e:"AI Assistant",t:'<span class="grad">Ask</span><span class="grad">Anything.</span>',d:"Ask any stock in plain language; answers from live data, in your language."}
];
var scr=document.getElementById('scr-live'),dev=document.getElementById('liveDevice'),mascot=document.getElementById('mascot'),
    capE=document.getElementById('cap-eye'),capT=document.getElementById('cap-title'),capD=document.getElementById('cap-desc'),dots=document.getElementById('dots');
var N=SCREENS.length,cur=-1;
for(var i=0;i<N;i++)dots.insertAdjacentHTML('beforeend','<i></i>');
function setStage(s){if(s===cur)return;cur=s;
  dev.classList.add('fade');capT.style.opacity=0;capD.style.opacity=0;capE.style.opacity=0;
  setTimeout(function(){
    scr.innerHTML=SCREENS[s];capE.textContent=CAPS[s].e;capT.innerHTML=CAPS[s].t;capD.textContent=CAPS[s].d;
    dev.classList.remove('fade');capT.style.opacity=1;capD.style.opacity=1;capE.style.opacity=1;
    var d=dots.children;for(var k=0;k<d.length;k++)d[k].className=(k===s?'on':'');
    mascot.style.transform='rotate('+(-12+s*5)+'deg)';
  },180);
}
setStage(0);
var scrolly=document.getElementById('features');
function stageScroll(){
  var r=scrolly.getBoundingClientRect(),vh=window.innerHeight;
  var total=scrolly.offsetHeight-vh;
  var p=Math.min(1,Math.max(0,(-r.top)/total));
  var s=Math.min(N-1,Math.floor(p*N));
  setStage(s);
}

// tape
var tk=[["MU","+9.6%",1],["NVDA","-3.1%",0],["LITE","+5.4%",1],["AAPL","+1.8%",1],["AVGO","-2.4%",0],["AAOI","+4.2%",1],["GOOGL","+2.6%",1],["SNDK","-1.8%",0],["SPACEX","+5.1%",1],["TSLA","-0.9%",0]];
var tp=document.getElementById('tape'),th='';for(var k=0;k<2;k++){tk.forEach(function(x){th+='<span><b>'+x[0]+'</b> <span class="'+(x[2]?'u':'d')+'">'+x[1]+'</span></span>';});}tp.innerHTML=th;

// reveal + nav
var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('show');io.unobserve(e.target);}});},{threshold:.12});
document.querySelectorAll('.reveal').forEach(function(el){io.observe(el);});
var nav=document.getElementById('nav'),ticking=false;
function onScroll(){nav.classList.toggle('scrolled',window.scrollY>20);stageScroll();ticking=false;}
window.addEventListener('scroll',function(){if(!ticking){requestAnimationFrame(onScroll);ticking=true;}},{passive:true});
window.addEventListener('resize',stageScroll,{passive:true});stageScroll();
</script>
</body>
</html>
