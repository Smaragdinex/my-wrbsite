---
const works = [
  { id: '01', title: 'CatInsight AI', subtitle: 'AI Stock Signals', href: '#' },
  { id: '02', title: '3D Museum', subtitle: 'WebGL Gallery', href: 'gallery.html' },
  { id: '03', title: 'Fluid Lab', subtitle: 'GPGPU Water', href: 'water.html' },
  { id: '04', title: 'Your Next Work', subtitle: 'Coming Soon', href: '#' },
];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>X-Arts - Selected Works</title>
    <meta
      name="description"
      content="Selected works from X-Arts, with an immersive colorful water ripple background."
    />
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    <style>
      :root {
        --bg: #050507;
        --fg: #f5f5f4;
        --muted: rgba(255, 255, 255, 0.42);
        --line: rgba(255, 255, 255, 0.085);
        --line-soft: rgba(255, 255, 255, 0.055);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        overflow-x: hidden;
        background:
          radial-gradient(1200px 700px at 50% -10%, rgba(55, 85, 135, 0.14), transparent 54%),
          radial-gradient(900px 600px at 90% 18%, rgba(224, 88, 176, 0.07), transparent 52%),
          radial-gradient(800px 560px at 8% 85%, rgba(68, 193, 255, 0.06), transparent 48%),
          var(--bg);
        color: var(--fg);
        font-family: Inter, Manrope, "Segoe UI", -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .ripple-canvas {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        pointer-events: none;
        z-index: 0;
        opacity: 0.98;
        mix-blend-mode: screen;
      }

      .page {
        position: relative;
        z-index: 1;
        min-height: 100vh;
        padding: 28px 32px 26px;
        display: flex;
        flex-direction: column;
      }

      .topbar {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .brand img {
        width: 52px;
        height: 52px;
        object-fit: cover;
        border-radius: 999px;
        filter: saturate(1.04) contrast(1.02);
        box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08), 0 18px 35px rgba(0, 0, 0, 0.36);
      }

      .brand-copy {
        display: grid;
        gap: 8px;
      }

      .eyebrow {
        font-size: 12px;
        letter-spacing: 0.36em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.44);
      }

      .brand-name {
        font-size: 14px;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.88);
      }

      .brand-right {
        display: grid;
        justify-items: end;
        gap: 10px;
        padding-top: 10px;
      }

      .brand-right .xarts {
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.28em;
        text-transform: uppercase;
      }

      .brand-right .studio {
        font-size: 12px;
        letter-spacing: 0.32em;
        color: rgba(255, 255, 255, 0.32);
      }

      .hero {
        margin-top: 64px;
        width: min(1090px, 100%);
      }

      .hero .section-label {
        font-size: 12px;
        letter-spacing: 0.38em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.34);
        margin-bottom: 20px;
      }

      .list {
        display: grid;
        gap: 0;
        border-top: 1px solid var(--line);
      }

      .item {
        position: relative;
        display: grid;
        grid-template-columns: 36px minmax(0, 1fr);
        align-items: center;
        gap: 24px;
        min-height: 128px;
        padding: 0 0 0 0;
        border-bottom: 1px solid var(--line-soft);
        isolation: isolate;
      }

      .item::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(255, 255, 255, 0.02), transparent 48%);
        opacity: 0;
        transition: opacity 220ms ease;
        z-index: -1;
      }

      .item:hover::before {
        opacity: 1;
      }

      .index {
        font-size: 13px;
        letter-spacing: 0.18em;
        color: rgba(255, 255, 255, 0.33);
        transform: translateY(2px);
      }

      .copy {
        display: grid;
        gap: 6px;
        padding: 26px 0;
      }

      .title {
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 18px;
        line-height: 0.95;
      }

      .title strong {
        font-size: clamp(44px, 4.7vw, 72px);
        font-weight: 800;
        letter-spacing: -0.06em;
      }

      .title span {
        font-size: clamp(16px, 1.7vw, 22px);
        font-weight: 500;
        color: rgba(255, 255, 255, 0.5);
      }

      .hover-dot {
        position: absolute;
        left: 54%;
        top: 50%;
        width: 12px;
        height: 12px;
        margin: -6px 0 0 -6px;
        border-radius: 999px;
        background: #fff;
        opacity: 0;
        transform: scale(0.6);
        transition: opacity 180ms ease, transform 180ms ease;
        box-shadow: 0 0 20px rgba(255, 255, 255, 0.7);
      }

      .item:hover .hover-dot {
        opacity: 1;
        transform: scale(1);
      }

      .footer {
        margin-top: auto;
        padding-top: 22px;
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 18px;
        color: rgba(255, 255, 255, 0.34);
        font-size: 12px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .footer strong {
        color: rgba(255, 255, 255, 0.58);
        font-weight: 600;
      }

      .footer .hint {
        text-transform: none;
        letter-spacing: 0.02em;
      }

      @media (max-width: 760px) {
        .page {
          padding: 20px 18px 18px;
        }

        .hero {
          margin-top: 48px;
        }

        .item {
          min-height: 102px;
          gap: 16px;
          grid-template-columns: 28px minmax(0, 1fr);
        }

        .title {
          gap: 10px;
        }

        .hover-dot {
          left: 58%;
        }

        .footer {
          align-items: flex-start;
          flex-direction: column;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .ripple-canvas {
          display: none;
        }

        .item,
        .item::before,
        .hover-dot {
          transition: none;
        }
      }
    </style>
  </head>
  <body>
    <canvas class="ripple-canvas" id="rippleCanvas" aria-hidden="true"></canvas>

    <main class="page">
      <header class="topbar">
        <div class="brand">
          <img src="/assets/images/leftcat1.gif" alt="X-Arts cat logo" />
          <div class="brand-copy">
            <div class="eyebrow">Selected Works</div>
            <div class="brand-name">X-Arts Studio</div>
          </div>
        </div>

        <div class="brand-right">
          <div class="xarts">X·ARTS</div>
          <div class="studio">STUDIO — 2026</div>
        </div>
      </header>

      <section class="hero">
        <div class="section-label">Selected Works</div>
        <nav class="list" aria-label="Selected works">
          {works.map((work) => (
            <a class="item" href={work.href} aria-label={`${work.id} ${work.title} ${work.subtitle}`}>
              <div class="index">{work.id}</div>
              <div class="copy">
                <div class="title">
                  <strong>{work.title}</strong>
                  <span>{work.subtitle}</span>
                </div>
              </div>
              <div class="hover-dot" aria-hidden="true"></div>
            </a>
          ))}
        </nav>
      </section>

      <footer class="footer">
        <div class="hint">移動滑鼠 - 背景像水 / 滑作品看畫面</div>
        <strong>xarts.games</strong>
      </footer>
    </main>

    <script is:inline>
      (function () {
        var canvas = document.getElementById('rippleCanvas');
        if (!canvas) return;
        var ctx = canvas.getContext('2d', { alpha: true });
        if (!ctx) return;

        var dpr = Math.min(2, Math.max(1, window.devicePixelRatio || 1));
        var width = 0;
        var height = 0;
        var ripples = [];
        var wisps = [];
        var pointerActive = false;
        var lastStamp = 0;
        var reducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function resize() {
          width = window.innerWidth;
          height = window.innerHeight;
          canvas.width = Math.round(width * dpr);
          canvas.height = Math.round(height * dpr);
          canvas.style.width = width + 'px';
          canvas.style.height = height + 'px';
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        }

        function palette(seed, alpha) {
          var hue = (seed * 37 + 180) % 360;
          var a = typeof alpha === 'number' ? alpha : 1;
          return {
            cyan: 'hsla(' + ((hue + 18) % 360) + ', 100%, 68%, ' + a + ')',
            magenta: 'hsla(' + ((hue + 300) % 360) + ', 100%, 68%, ' + a + ')',
            yellow: 'hsla(' + ((hue + 76) % 360) + ', 100%, 68%, ' + a + ')',
            blue: 'hsla(' + ((hue + 222) % 360) + ', 100%, 64%, ' + a + ')',
          };
        }

        function spawn(x, y, strength) {
          var seed = (x * 0.019 + y * 0.013 + performance.now() * 0.00042) % 360;
          ripples.push({
            x: x,
            y: y,
            seed: seed,
            radius: 0,
            width: 1.5 + Math.random() * 2.6,
            max: 140 + Math.random() * 180 * strength,
            life: 1,
            pulse: 0.15 + Math.random() * 0.18,
            wobble: 0.12 + Math.random() * 0.18,
          });
          wisps.push({
            x: x,
            y: y,
            seed: seed,
            size: 90 + Math.random() * 100,
            life: 1,
            driftX: (Math.random() - 0.5) * 0.6,
            driftY: (Math.random() - 0.5) * 0.6,
          });
          if (ripples.length > 32) ripples.shift();
          if (wisps.length > 16) wisps.shift();
        }

        function coords(ev) {
          var rect = canvas.getBoundingClientRect();
          return {
            x: ev.clientX - rect.left,
            y: ev.clientY - rect.top,
          };
        }

        function onMove(ev) {
          if (reducedMotion) return;
          pointerActive = true;
          var now = performance.now();
          if (now - lastStamp < 18) return;
          lastStamp = now;
          var p = coords(ev);
          spawn(p.x, p.y, 1);
        }

        function onDown(ev) {
          if (reducedMotion) return;
          pointerActive = true;
          var p = coords(ev);
          spawn(p.x, p.y, 1.25);
          spawn(p.x + 14, p.y - 8, 0.82);
        }

        function drawBackdrop() {
          ctx.clearRect(0, 0, width, height);
          var grad = ctx.createRadialGradient(width * 0.5, height * 0.35, 0, width * 0.5, height * 0.35, Math.max(width, height) * 0.85);
          grad.addColorStop(0, 'rgba(4, 6, 10, 0.92)');
          grad.addColorStop(0.45, 'rgba(4, 6, 10, 0.96)');
          grad.addColorStop(1, 'rgba(0, 0, 0, 1)');
          ctx.fillStyle = grad;
          ctx.fillRect(0, 0, width, height);

          var ambient = ctx.createLinearGradient(0, 0, width, height);
          ambient.addColorStop(0, 'rgba(49, 82, 163, 0.08)');
          ambient.addColorStop(0.24, 'rgba(82, 161, 255, 0.07)');
          ambient.addColorStop(0.52, 'rgba(236, 86, 172, 0.07)');
          ambient.addColorStop(0.78, 'rgba(108, 230, 255, 0.05)');
          ambient.addColorStop(1, 'rgba(255, 202, 92, 0.05)');
          ctx.fillStyle = ambient;
          ctx.fillRect(0, 0, width, height);
        }

        function drawWisps(time) {
          ctx.save();
          ctx.globalCompositeOperation = 'screen';
          ctx.filter = 'blur(24px)';
          for (var i = wisps.length - 1; i >= 0; i--) {
            var wisp = wisps[i];
            wisp.life *= 0.985;
            wisp.x += Math.sin(time * 0.0003 + wisp.seed) * 0.14 + wisp.driftX;
            wisp.y += Math.cos(time * 0.00028 + wisp.seed) * 0.14 + wisp.driftY;
            if (wisp.life < 0.04) {
              wisps.splice(i, 1);
              continue;
            }
            var pal = palette(wisp.seed, 0.16 * wisp.life);
            var glow = ctx.createRadialGradient(wisp.x, wisp.y, 0, wisp.x, wisp.y, wisp.size);
            glow.addColorStop(0, pal.cyan);
            glow.addColorStop(0.34, pal.magenta);
            glow.addColorStop(0.67, pal.yellow);
            glow.addColorStop(1, 'rgba(0, 0, 0, 0)');
            ctx.fillStyle = glow;
            ctx.beginPath();
            ctx.arc(wisp.x, wisp.y, wisp.size, 0, Math.PI * 2);
            ctx.fill();
          }
          ctx.restore();
          ctx.filter = 'none';
        }

        function drawRipple(ripple, time) {
          var pal = palette(ripple.seed, Math.max(0.04, ripple.life * 0.96));
          var segments = 96;
          var radius = ripple.radius;
          var wobbleA = ripple.wobble * 34;
          var wobbleB = ripple.wobble * 14;
          var lineAlpha = Math.max(0, 0.9 * ripple.life);

          function drawWavyRing(scale, hueShift, alpha, strokeWidth) {
            ctx.save();
            ctx.beginPath();
            for (var i = 0; i <= segments; i++) {
              var t = (i / segments) * Math.PI * 2;
              var wobble =
                Math.sin(t * 6.0 + time * 0.002 + ripple.seed * 0.04) * wobbleA * 0.23 +
                Math.sin(t * 11.0 - time * 0.0014 + ripple.seed * 0.08) * wobbleB * 0.35;
              var rr = radius * scale + wobble;
              var x = ripple.x + Math.cos(t) * rr;
              var y = ripple.y + Math.sin(t) * rr * 0.992;
              if (i === 0) ctx.moveTo(x, y);
              else ctx.lineTo(x, y);
            }
            ctx.closePath();
            ctx.strokeStyle = 'hsla(' + hueShift + ', 100%, 68%, ' + alpha + ')';
            ctx.lineWidth = strokeWidth;
            ctx.stroke();
            ctx.restore();
          }

          ctx.save();
          ctx.globalCompositeOperation = 'lighter';
          ctx.filter = 'blur(0.35px)';

          var fill = ctx.createRadialGradient(ripple.x, ripple.y, 0, ripple.x, ripple.y, radius + 150);
          fill.addColorStop(0, 'rgba(255,255,255,0)');
          fill.addColorStop(0.14, 'rgba(255,255,255,0)');
          fill.addColorStop(0.34, pal.cyan);
          fill.addColorStop(0.56, pal.magenta);
          fill.addColorStop(0.78, pal.yellow);
          fill.addColorStop(1, 'rgba(0,0,0,0)');
          ctx.fillStyle = fill;
          ctx.beginPath();
          ctx.arc(ripple.x, ripple.y, radius * 0.74 + 18, 0, Math.PI * 2);
          ctx.fill();

          drawWavyRing(1.0, (ripple.seed * 2.5 + 185) % 360, 0.92 * lineAlpha, ripple.width * 1.35);
          drawWavyRing(0.74, (ripple.seed * 2.1 + 245) % 360, 0.6 * lineAlpha, ripple.width * 0.92);
          drawWavyRing(1.22, (ripple.seed * 2.8 + 320) % 360, 0.42 * lineAlpha, ripple.width * 0.86);

          var core = ctx.createRadialGradient(ripple.x, ripple.y, 0, ripple.x, ripple.y, radius * 0.56 + 44);
          core.addColorStop(0, 'rgba(255,255,255,0.12)');
          core.addColorStop(0.2, 'rgba(255,255,255,0.05)');
          core.addColorStop(0.42, pal.blue);
          core.addColorStop(0.66, pal.magenta);
          core.addColorStop(1, 'rgba(0,0,0,0)');
          ctx.fillStyle = core;
          ctx.beginPath();
          ctx.arc(ripple.x, ripple.y, radius * 0.54 + 24, 0, Math.PI * 2);
          ctx.fill();
          ctx.restore();
        }

        function step(time) {
          drawBackdrop();
          drawWisps(time);

          ctx.save();
          ctx.globalCompositeOperation = 'lighter';
          for (var i = ripples.length - 1; i >= 0; i--) {
            var ripple = ripples[i];
            ripple.radius += 2.2 + ripple.life * 1.8;
            ripple.life *= 0.977;
            if (ripple.radius > ripple.max || ripple.life < 0.035) {
              ripples.splice(i, 1);
              continue;
            }
            drawRipple(ripple, time);
          }
          ctx.restore();

          if (!pointerActive && !reducedMotion && ripples.length < 8) {
            // Keep the background subtly alive even when the cursor is still.
            if (Math.random() < 0.025) {
              var x = width * (0.18 + Math.random() * 0.62);
              var y = height * (0.18 + Math.random() * 0.54);
              spawn(x, y, 0.6);
            }
          }

          requestAnimationFrame(step);
        }

        resize();
        requestAnimationFrame(step);
        window.addEventListener('resize', resize, { passive: true });
        window.addEventListener('pointermove', onMove, { passive: true });
        window.addEventListener('pointerdown', onDown, { passive: true });
      })();
    </script>
  </body>
</html>
